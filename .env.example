# ═══════════════════════════════════════════════════
# EthicFlow — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ─── Environment ───
NODE_ENV=development                    # development | production

# ─── Database ───
DB_NAME=ethicflow
DB_USER=ethicflow
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=localhost                       # "localhost" for dev, "db" for docker prod
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ─── pgAdmin (DEV only) ───
PGADMIN_EMAIL=admin@ethicflow.dev
PGADMIN_PASSWORD=admin123

# ─── JWT Authentication ───
JWT_SECRET=CHANGE_ME_64_RANDOM_CHARS_MINIMUM_USE_openssl_rand_hex_32
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=
JWT_SECRET_VERSION=v1
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
# SSO one-time code TTL (milliseconds). Keep short to limit replay window.
AUTH_EXCHANGE_TTL_MS=90000
ACCESS_TOKEN_COOKIE_NAME=ef_access
REFRESH_TOKEN_COOKIE_NAME=ef_refresh

# ─── Ports ───
API_PORT=5000                           # Backend API port
WEB_PORT=5173                           # Frontend port (dev: 5173, prod: 80)

# ─── Frontend URL (for email links) ───
FRONTEND_URL=http://localhost:5173      # PROD: https://ethics.institution.ac.il

# ═══════════════════════════════════════════════════
# INSTITUTION SETTINGS (customize per institution)
# ═══════════════════════════════════════════════════
INSTITUTION_NAME_HE=המוסד האקדמי
INSTITUTION_NAME_EN=Academic Institution
INSTITUTION_LOGO=/logos/default.png     # Path to logo file
INSTITUTION_PRIMARY_COLOR=#1e40af      # Brand color
INSTITUTION_DOMAIN=ethics.institution.ac.il
DEFAULT_LANGUAGE=he                     # he | en
ACADEMIC_YEAR_START=10                  # Month (10=October/Tishrei)
PDF_LOGO_PATH=                          # Optional: EthicFlow/system logo path for PDF header (png/jpg/jpeg/webp/svg)

# ═══════════════════════════════════════════════════
# PLUGGABLE SERVICES (change provider by changing value)
# ═══════════════════════════════════════════════════

# ─── AI Provider (mock | gemini | openai | azure_openai) ───
AI_PROVIDER=mock
GEMINI_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ─── Email Provider (console | smtp | microsoft | gmail) ───
# console = print to terminal (dev only)
# smtp    = standard SMTP (nodemailer)
# microsoft = Microsoft Graph API (org email via Outlook/Exchange)
# gmail   = Gmail API (Phase 2)
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ethics@institution.ac.il
SMTP_FROM_NAME=ועדת אתיקה
# Microsoft Graph Email — requires Azure AD App with Mail.Send permission
# Azure Portal → App registrations → API permissions → Microsoft Graph → Mail.Send (Application)
MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_TENANT_ID=
# Gmail API — requires Google Cloud project + OAuth2 credentials with Gmail API enabled
# See DEPLOYMENT.md → "Google Integration Setup" for step-by-step instructions
# To generate a refresh token: run `node scripts/generate-gmail-token.js` after filling client vars
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── Storage Provider (local | s3 | azure_blob) ───
STORAGE_PROVIDER=local
UPLOAD_MAX_SIZE_MB=20
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,jpg,png,xlsx
# S3 (Phase 2)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Azure Blob (Phase 2)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# ─── Calendar Provider (internal | microsoft | google) ───
# internal  = meetings saved to DB only (default)
# microsoft = sync to Outlook via Microsoft Graph API
CALENDAR_PROVIDER=internal
# Microsoft Calendar — requires Azure AD App with Calendars.ReadWrite permission
# Azure Portal → App registrations → API permissions → Microsoft Graph → Calendars.ReadWrite (Application)
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT_ID=
MICROSOFT_CALENDAR_ORGANIZER_EMAIL=     # e.g. ethics@institution.ac.il (must be a licensed mailbox)
# Google Calendar — requires Google Cloud service account with Calendar API enabled
# GOOGLE_SERVICE_ACCOUNT_JSON  = inline JSON string (preferred for Docker/prod)
# GOOGLE_CALENDAR_CREDENTIALS  = path to service account JSON file (dev)
# GOOGLE_CALENDAR_IMPERSONATE  = email to impersonate (only for Workspace + domain-wide delegation)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=primary              # Calendar ID or shared calendar email
GOOGLE_CALENDAR_IMPERSONATE=            # e.g. ethics@institution.ac.il

# ─── Personal calendar OAuth (hybrid sync) ───
# Token encryption key for per-user calendar tokens (required in production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Google personal calendar OAuth (fallbacks to GOOGLE_AUTH_* if empty)
GOOGLE_CALENDAR_USER_CLIENT_ID=
GOOGLE_CALENDAR_USER_CLIENT_SECRET=
GOOGLE_CALENDAR_USER_REDIRECT_URI=http://localhost:5000/api/calendar/callback/google

# Microsoft personal calendar OAuth (fallbacks to MICROSOFT_AUTH_* if empty)
MICROSOFT_CALENDAR_USER_CLIENT_ID=
MICROSOFT_CALENDAR_USER_CLIENT_SECRET=
MICROSOFT_CALENDAR_USER_TENANT_ID=common
MICROSOFT_CALENDAR_USER_REDIRECT_URI=http://localhost:5000/api/calendar/callback/microsoft

# ─── Auth / SSO (local | microsoft | google) ───
# local     = email + password only (default)
# microsoft = Login with Microsoft (Entra ID / Azure AD)
AUTH_PROVIDER=local
# Microsoft SSO — requires Azure AD App with OIDC redirect
# Azure Portal → App registrations → Authentication → Redirect URI:
#   http://localhost:5000/api/auth/microsoft/callback (dev)
#   https://yourdomain.com/api/auth/microsoft/callback (prod)
# Required API scopes: openid, profile, email, User.Read (Delegated)
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
MICROSOFT_AUTH_TENANT_ID=              # Your tenant ID, or 'common' for multi-tenant
MICROSOFT_AUTH_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback
# Google OAuth2 SSO — requires Google Cloud project + OAuth2 Web Client credentials
# Google Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web application
# Authorized redirect URIs: http://localhost:5000/api/auth/google/callback (dev)
#                            https://yourdomain.com/api/auth/google/callback (prod)
# GOOGLE_AUTH_ALLOWED_DOMAIN = restrict to a Google Workspace domain (optional)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_AUTH_ALLOWED_DOMAIN=            # e.g. lev.ac.il (leave empty for any Google account)

# ═══════════════════════════════════════════════════
# SLA DEFAULTS (can be changed in admin panel)
# ═══════════════════════════════════════════════════
SLA_TRIAGE_DAYS=3
SLA_REVIEW_DAYS=14
SLA_REVISION_DAYS=30
SLA_APPROVAL_DAYS=5
SLA_WARNING_HOURS=48

# ═══════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=60000              # 1 minute
RATE_LIMIT_MAX=100                      # requests per window
LOGIN_RATE_LIMIT_MAX=5                  # login attempts
LOGIN_RATE_LIMIT_WINDOW_MS=900000       # 15 minutes lockout
LOGIN_LOCKOUT_MAX_ATTEMPTS=8            # failed attempts per account before temporary lock
LOGIN_LOCKOUT_MINUTES=15                # lock duration per account
AI_RATE_LIMIT_WINDOW_MS=3600000         # 1 hour
AI_RATE_LIMIT_MAX=20                    # analysis requests per hour per IP
SESSION_TIMEOUT_MINUTES=30
BCRYPT_ROUNDS=12
