# EthicFlow — Production Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file and fill in real values before deploying.
# On Railway: set these in each service's Variables tab.
# On VPS:     copy to .env.prod and reference with --env-file.
#
# NEVER commit real secrets to version control.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────
# On Railway: use the reference variable from the PostgreSQL addon:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# On VPS with Docker Compose: built from the parts below.
DATABASE_URL=postgresql://ethicflow:CHANGE_ME_DB_PASSWORD@localhost:5432/ethicflow
DB_NAME=ethicflow
DB_USER=ethicflow
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Auth ─────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_here
# SSO one-time code TTL (milliseconds). Recommended: 60000-120000.
AUTH_EXCHANGE_TTL_MS=90000

# ── URLs (fill in AFTER first deploy to get Railway domains) ─
# Backend service public URL  (set on the FRONTEND service as BACKEND_URL)
BACKEND_URL=https://ethicflow-api-XXXX.up.railway.app
# Frontend service public URL (set on the BACKEND service as FRONTEND_URL for CORS)
FRONTEND_URL=https://ethicflow-web-XXXX.up.railway.app

# ── Pluggable Services ───────────────────────────────────────
# EMAIL_PROVIDER: console | smtp | sendgrid
EMAIL_PROVIDER=console
# AI_PROVIDER: mock | gemini
AI_PROVIDER=mock
# STORAGE_PROVIDER: local | s3 | azure
STORAGE_PROVIDER=local
# CALENDAR_PROVIDER: internal | google | microsoft
CALENDAR_PROVIDER=internal

# ── Ports (Railway ignores these — it assigns ports automatically) ─
API_PORT=5000
