# EthicFlow — Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit real secrets to source control.

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production
API_PORT=5000
WEB_PORT=80

# ── Database ─────────────────────────────────────────────────
# Railway: use provider DATABASE_URL reference variable.
# VPS: keep DB_* and DATABASE_URL aligned with docker-compose.prod.yml.
DB_NAME=ethicflow
DB_USER=ethicflow
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Core URLs ────────────────────────────────────────────────
# FRONTEND_URL is mandatory in production; backend startup fails if missing.
FRONTEND_URL=https://ethics.yourinstitution.ac.il
BACKEND_URL=https://api.ethics.yourinstitution.ac.il

# ── Auth + Session Security ──────────────────────────────────
# Generate JWT secret:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_RANDOM_CHARS_MINIMUM
JWT_SECRET_CURRENT=
JWT_SECRET_PREVIOUS=
JWT_SECRET_VERSION=v1
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
# Keep short to reduce replay window for one-time SSO exchange code.
AUTH_EXCHANGE_TTL_MS=90000
ACCESS_TOKEN_COOKIE_NAME=ef_access
REFRESH_TOKEN_COOKIE_NAME=ef_refresh
LOGIN_LOCKOUT_MAX_ATTEMPTS=8
LOGIN_LOCKOUT_MINUTES=15
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=20

# ── Provider Selection (institution profile: Microsoft primary) ─────────────
AUTH_PROVIDER=microsoft
EMAIL_PROVIDER=microsoft
CALENDAR_PROVIDER=microsoft
STORAGE_PROVIDER=local
AI_PROVIDER=mock

# ── Microsoft SSO (Entra ID) ─────────────────────────────────
MICROSOFT_AUTH_CLIENT_ID=
MICROSOFT_AUTH_CLIENT_SECRET=
MICROSOFT_AUTH_TENANT_ID=
MICROSOFT_AUTH_REDIRECT_URI=https://ethics.yourinstitution.ac.il/api/auth/microsoft/callback

# ── Microsoft Graph Email (Application permission: Mail.Send) ───────────────
MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_TENANT_ID=
SMTP_FROM=ethics@yourinstitution.ac.il
SMTP_FROM_NAME=Ethics Committee

# ── Microsoft Calendar (Application permission: Calendars.ReadWrite) ────────
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT_ID=
MICROSOFT_CALENDAR_ORGANIZER_EMAIL=ethics@yourinstitution.ac.il

# ── Google Personal Calendar OAuth (user-level link, optional) ──────────────
GOOGLE_CALENDAR_USER_CLIENT_ID=
GOOGLE_CALENDAR_USER_CLIENT_SECRET=
GOOGLE_CALENDAR_USER_REDIRECT_URI=https://ethics.yourinstitution.ac.il/api/calendar/callback/google

# ── Microsoft Personal Calendar OAuth (optional override) ────────────────────
# Leave CLIENT_ID/SECRET empty to fallback to MICROSOFT_AUTH_*.
MICROSOFT_CALENDAR_USER_CLIENT_ID=
MICROSOFT_CALENDAR_USER_CLIENT_SECRET=
MICROSOFT_CALENDAR_USER_TENANT_ID=common
MICROSOFT_CALENDAR_USER_REDIRECT_URI=https://ethics.yourinstitution.ac.il/api/calendar/callback/microsoft

# ── Personal Calendar Token Security ─────────────────────────
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
AZURE_KEY_VAULT_URI=
AZURE_KEY_VAULT_JWT_SECRET_NAME=

# ── Optional: SMTP fallback provider values (if EMAIL_PROVIDER=smtp) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Optional: Storage provider values ────────────────────────
UPLOAD_MAX_SIZE_MB=20
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,jpg,png,xlsx
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
