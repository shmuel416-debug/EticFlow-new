// =============================================================
// EthicFlow — Prisma Schema
// Database: PostgreSQL 16
// Conventions: Models=PascalCase→@@map("snake_case"), Fields=camelCase→@map("snake_case")
// Soft delete: isActive Boolean on all main entities
// SSO-ready: User.passwordHash nullable, authProvider enum
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  RESEARCHER
  SECRETARY
  REVIEWER
  CHAIRMAN
  ADMIN
}

enum AuthProvider {
  LOCAL
  MICROSOFT
  GOOGLE
}

enum Track {
  FULL       // Full committee review
  EXPEDITED  // Expedited review
  EXEMPT     // Exempt from review
}

enum SubStatus {
  DRAFT
  SUBMITTED
  IN_TRIAGE
  ASSIGNED
  IN_REVIEW
  PENDING_REVISION
  APPROVED
  REJECTED
  WITHDRAWN
  CONTINUED  // Continuation of approved research
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Decision {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
  REVISION_REQUIRED
}

enum ProtocolStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  ARCHIVED
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
}

enum NotificationType {
  SUBMISSION_RECEIVED
  SUBMISSION_ASSIGNED
  REVIEW_REQUESTED
  REVISION_REQUIRED
  APPROVED
  REJECTED
  MEETING_SCHEDULED
  MEETING_REMINDER
  SLA_WARNING
  SLA_BREACH
  PROTOCOL_SIGNATURE_REQUESTED
  SYSTEM
}

enum DocumentSource {
  UPLOADED   // Uploaded by researcher
  GENERATED  // Generated by system (immutable)
}

// ─────────────────────────────────────────────
// 1. USER
// ─────────────────────────────────────────────

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String?      @map("password_hash")       // NULL for SSO users
  fullName          String       @map("full_name")
  role              Role         @default(RESEARCHER)
  department        String?
  phone             String?
  authProvider      AuthProvider @default(LOCAL) @map("auth_provider")
  externalId        String?      @map("external_id")         // SSO provider Object ID
  resetToken        String?      @map("reset_token")
  resetTokenExpiry  DateTime?    @map("reset_token_expiry")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  submissions       Submission[]       @relation("SubmissionAuthor")
  assignedReviews   Submission[]       @relation("SubmissionReviewer")
  comments          Comment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  meetingAttendees  MeetingAttendee[]
  protocolSignatures ProtocolSignature[]
  uploadedDocuments Document[]         @relation("DocumentUploader")
  aiAnalyses        AIAnalysis[]

  @@map("users")
}

// ─────────────────────────────────────────────
// 2. FORM CONFIG
// ─────────────────────────────────────────────

model FormConfig {
  id          String   @id @default(uuid())
  name        String
  nameEn      String   @map("name_en")
  version     Int      @default(1)
  schemaJson  Json     @map("schema_json")   // JSON Schema for dynamic rendering
  isActive    Boolean  @default(true) @map("is_active")
  isPublished Boolean  @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  submissions Submission[]

  @@map("form_configs")
}

// ─────────────────────────────────────────────
// 3. SUBMISSION
// ─────────────────────────────────────────────

model Submission {
  id            String    @id @default(uuid())
  applicationId String    @unique @map("application_id")  // ETH-{YEAR}-{SEQ}
  title         String
  track         Track     @default(FULL)
  status        SubStatus @default(DRAFT)
  formConfigId  String    @map("form_config_id")
  authorId      String    @map("author_id")
  reviewerId    String?   @map("reviewer_id")
  parentId      String?   @map("parent_id")               // For continuation submissions
  isActive      Boolean   @default(true) @map("is_active")
  submittedAt   DateTime? @map("submitted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  formConfig   FormConfig         @relation(fields: [formConfigId], references: [id])
  author       User               @relation("SubmissionAuthor", fields: [authorId], references: [id])
  reviewer     User?              @relation("SubmissionReviewer", fields: [reviewerId], references: [id])
  parent       Submission?        @relation("SubmissionContinuation", fields: [parentId], references: [id])
  continuations Submission[]      @relation("SubmissionContinuation")
  versions     SubmissionVersion[]
  comments     Comment[]
  slaTracking  SLATracking?
  aiAnalyses   AIAnalysis[]
  agendaItems  MeetingAgendaItem[]
  documents    Document[]

  @@map("submissions")
}

// ─────────────────────────────────────────────
// 4. SUBMISSION VERSION
// ─────────────────────────────────────────────

model SubmissionVersion {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  versionNum   Int      @map("version_num")
  dataJson     Json     @map("data_json")    // Full form data snapshot
  changedBy    String   @map("changed_by")  // User ID
  changeNote   String?  @map("change_note")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])

  @@unique([submissionId, versionNum])
  @@map("submission_versions")
}

// ─────────────────────────────────────────────
// 5. COMMENT
// ─────────────────────────────────────────────

model Comment {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  authorId     String   @map("author_id")
  content      String
  fieldKey     String?  @map("field_key")   // Optional: comment on a specific field
  isInternal   Boolean  @default(false) @map("is_internal")  // Internal = reviewers only
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])
  author     User       @relation(fields: [authorId], references: [id])

  @@map("comments")
}

// ─────────────────────────────────────────────
// 6. SLA TRACKING
// ─────────────────────────────────────────────

model SLATracking {
  id              String    @id @default(uuid())
  submissionId    String    @unique @map("submission_id")
  triageDue       DateTime? @map("triage_due")
  reviewDue       DateTime? @map("review_due")
  revisionDue     DateTime? @map("revision_due")
  approvalDue     DateTime? @map("approval_due")
  triageCompleted DateTime? @map("triage_completed")
  reviewCompleted DateTime? @map("review_completed")
  isBreached      Boolean   @default(false) @map("is_breached")
  warningsSent    Int       @default(0) @map("warnings_sent")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("sla_tracking")
}

// ─────────────────────────────────────────────
// 7. AI ANALYSIS
// ─────────────────────────────────────────────

model AIAnalysis {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  requestedBy  String   @map("requested_by")  // User ID
  provider     String                          // "mock" | "gemini"
  prompt       String
  resultJson   Json     @map("result_json")   // Advisory only — never blocks
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])
  requester  User       @relation(fields: [requestedBy], references: [id])

  @@map("ai_analyses")
}

// ─────────────────────────────────────────────
// 8. AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")     // Nullable for system actions
  action     String                        // e.g. "submission.approved"
  entityType String   @map("entity_type") // e.g. "Submission"
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metaJson   Json?    @map("meta_json")   // Extra context
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// 9. INSTITUTION SETTING
// ─────────────────────────────────────────────

model InstitutionSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  valueType String   @default("string") @map("value_type")  // "string"|"number"|"boolean"|"json"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("institution_settings")
}

// ─────────────────────────────────────────────
// 10. MEETING
// ─────────────────────────────────────────────

model Meeting {
  id           String        @id @default(uuid())
  title        String
  scheduledAt  DateTime      @map("scheduled_at")
  location     String?
  meetingLink  String?       @map("meeting_link")
  status       MeetingStatus @default(SCHEDULED)
  agendaNote   String?       @map("agenda_note")
  minutesNote  String?       @map("minutes_note")
  isActive           Boolean       @default(true) @map("is_active")
  externalCalendarId String?       @map("external_calendar_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  agendaItems MeetingAgendaItem[]
  attendees   MeetingAttendee[]
  protocols   Protocol[]

  @@map("meetings")
}

// ─────────────────────────────────────────────
// 11. MEETING AGENDA ITEM
// ─────────────────────────────────────────────

model MeetingAgendaItem {
  id           String    @id @default(uuid())
  meetingId    String    @map("meeting_id")
  submissionId String    @map("submission_id")
  orderIndex   Int       @map("order_index")
  decision     Decision  @default(PENDING)
  decisionNote String?   @map("decision_note")
  duration     Int?                            // Minutes allocated
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  meeting    Meeting    @relation(fields: [meetingId], references: [id])
  submission Submission @relation(fields: [submissionId], references: [id])

  @@unique([meetingId, submissionId])
  @@map("meeting_agenda_items")
}

// ─────────────────────────────────────────────
// 12. MEETING ATTENDEE
// ─────────────────────────────────────────────

model MeetingAttendee {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  attended  Boolean  @default(false)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_attendees")
}

// ─────────────────────────────────────────────
// 13. PROTOCOL
// ─────────────────────────────────────────────

model Protocol {
  id          String         @id @default(uuid())
  meetingId   String         @map("meeting_id")
  title       String
  contentJson Json           @map("content_json")  // Rich text as JSON
  status      ProtocolStatus @default(DRAFT)
  isActive    Boolean        @default(true) @map("is_active")
  finalizedAt DateTime?      @map("finalized_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  meeting    Meeting             @relation(fields: [meetingId], references: [id])
  signatures ProtocolSignature[]
  documents  Document[]

  @@map("protocols")
}

// ─────────────────────────────────────────────
// 14. PROTOCOL SIGNATURE
// ─────────────────────────────────────────────

model ProtocolSignature {
  id          String          @id @default(uuid())
  protocolId  String          @map("protocol_id")
  userId      String          @map("user_id")
  status      SignatureStatus @default(PENDING)
  token       String?         @unique   // Email link token
  tokenExpiry DateTime?       @map("token_expiry")
  signedAt    DateTime?       @map("signed_at")
  ipAddress   String?         @map("ip_address")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  protocol Protocol @relation(fields: [protocolId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([protocolId, userId])
  @@map("protocol_signatures")
}

// ─────────────────────────────────────────────
// 15. NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  type       NotificationType
  titleKey   String           @map("title_key")   // i18n key
  bodyKey    String           @map("body_key")    // i18n key
  metaJson   Json?            @map("meta_json")   // Dynamic values for i18n interpolation
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at")
  isActive   Boolean          @default(true) @map("is_active")
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// 16. DOCUMENT
// ─────────────────────────────────────────────

model Document {
  id           String         @id @default(uuid())
  filename     String
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  storagePath  String         @map("storage_path")   // Relative path in STORAGE_PROVIDER
  source       DocumentSource @default(UPLOADED)
  submissionId String?        @map("submission_id")
  protocolId   String?        @map("protocol_id")
  uploadedById String?        @map("uploaded_by_id") // NULL for system-generated
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")

  // Relations
  submission Submission? @relation(fields: [submissionId], references: [id])
  protocol   Protocol?   @relation(fields: [protocolId], references: [id])
  uploadedBy User?       @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@map("documents")
}
