// =============================================================
// EthicFlow — Prisma Schema
// Database: PostgreSQL 16
// Conventions: Models=PascalCase→@@map("snake_case"), Fields=camelCase→@map("snake_case")
// Soft delete: isActive Boolean on all main entities
// SSO-ready: User.passwordHash nullable, authProvider enum
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  RESEARCHER
  SECRETARY
  REVIEWER
  CHAIRMAN
  ADMIN
}

enum ConflictScope {
  SUBMISSION
  USER
  DEPARTMENT
  GLOBAL
}

enum AuthProvider {
  LOCAL
  MICROSOFT
  GOOGLE
}

enum CalendarProvider {
  NONE
  GOOGLE
  MICROSOFT
}

enum Track {
  FULL       // Full committee review
  EXPEDITED  // Expedited review
  EXEMPT     // Exempt from review
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Decision {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
  REVISION_REQUIRED
}

enum ProtocolStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  ARCHIVED
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
}

enum NotificationType {
  SUBMISSION_RECEIVED
  SUBMISSION_ASSIGNED
  REVIEW_REQUESTED
  REVISION_REQUIRED
  APPROVED
  REJECTED
  MEETING_SCHEDULED
  MEETING_REMINDER
  SLA_WARNING
  SLA_BREACH
  PROTOCOL_SIGNATURE_REQUESTED
  SYSTEM
}

enum CalendarSyncStatus {
  PENDING
  SYNCED
  FAILED
  CANCELLED
}

enum DocumentSource {
  UPLOADED   // Uploaded by researcher
  GENERATED  // Generated by system (immutable)
}

enum StatusAction {
  VIEW
  EDIT
  COMMENT
  UPLOAD_DOC
  DELETE_DOC
  VIEW_INTERNAL
  TRANSITION
  ASSIGN
  SUBMIT_REVIEW
  RECORD_DECISION
}

enum SlaPhase {
  TRIAGE
  REVIEW
  APPROVAL
  COMPLETED
}

enum DataSubjectRequestType {
  ACCESS
  ERASURE
}

enum DataSubjectRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum CommitteeVoteDecision {
  APPROVED
  REJECTED
  REVISION_REQUIRED
  ABSTAIN
}

enum ChecklistAnswerType {
  ADEQUACY        // מספק / לא מספק
  YES_NO          // כן / לא (informational)
  YES_NO_PROBLEM  // כן / לא (yes = ethical problem)
}

enum ChecklistReviewStatus {
  DRAFT
  SUBMITTED
}

enum ChecklistRecommendation {
  EXEMPT
  APPROVED
  APPROVED_CONDITIONAL
  REVISION_REQUIRED
  REJECTED
}

// ─────────────────────────────────────────────
// 1. USER
// ─────────────────────────────────────────────

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String?      @map("password_hash")       // NULL for SSO users
  fullName          String       @map("full_name")
  roles             Role[]       @default([RESEARCHER])
  department        String?
  phone             String?
  authProvider      AuthProvider @default(LOCAL) @map("auth_provider")
  externalId        String?      @map("external_id")         // SSO provider Object ID
  calendarProvider   CalendarProvider @default(NONE) @map("calendar_provider")
  calendarSyncEnabled Boolean      @default(false) @map("calendar_sync_enabled")
  calendarAccessToken String?      @map("calendar_access_token")
  calendarRefreshToken String?     @map("calendar_refresh_token")
  calendarTokenExpiry DateTime?    @map("calendar_token_expiry")
  calendarEmail       String?      @map("calendar_email")
  resetToken        String?      @map("reset_token")
  resetTokenExpiry  DateTime?    @map("reset_token_expiry")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockoutUntil      DateTime?    @map("lockout_until")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  submissions       Submission[]       @relation("SubmissionAuthor")
  assignedReviews   Submission[]       @relation("SubmissionReviewer")
  comments          Comment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  authExchangeCodes AuthExchangeCode[]
  refreshTokens     RefreshToken[]
  meetingAttendees  MeetingAttendee[]
  meetingCalendarSyncs MeetingCalendarSync[]
  protocolSignatures ProtocolSignature[]
  uploadedDocuments Document[]         @relation("DocumentUploader")
  uploadedSystemTemplates SystemTemplate[]
  aiAnalyses        AIAnalysis[]
  privacyConsents   PrivacyConsent[]
  dsrRequests       DataSubjectRequest[]
  submissionVotes   SubmissionVote[]
  declaredConflicts    ConflictDeclaration[]        @relation("ConflictDeclarer")
  targetConflicts      ConflictDeclaration[]        @relation("ConflictTargetUser")
  checklistReviews     ReviewerChecklistReview[]    @relation("ReviewerChecklistReviews")

  @@map("users")
}

// ─────────────────────────────────────────────
// 1.1 AUTH EXCHANGE CODE (SSO handoff)
// ─────────────────────────────────────────────

model AuthExchangeCode {
  id        String   @id @default(uuid())
  codeHash  String   @unique @map("code_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([expiresAt])
  @@index([userId, createdAt])
  @@map("auth_exchange_codes")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique @map("token_hash")
  userId     String   @map("user_id")
  expiresAt  DateTime @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?  @map("replaced_by")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// 2. FORM CONFIG
// ─────────────────────────────────────────────

model FormConfig {
  id               String   @id @default(uuid())
  name             String
  nameEn           String   @map("name_en")
  version          Int      @default(1)
  schemaJson       Json     @map("schema_json")   // JSON Schema for dynamic rendering
  instructionsHe   String?  @map("instructions_he") @db.Text
  instructionsEn   String?  @map("instructions_en") @db.Text
  attachmentsList  Json?    @map("attachments_list")  // [{id, name, nameEn, required, acceptedTypes[], note}]
  isActive         Boolean  @default(true) @map("is_active")
  isPublished      Boolean  @default(false) @map("is_published")
  publishedAt      DateTime? @map("published_at")
  duplicatedFromId String?  @map("duplicated_from_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  submissions      Submission[]
  duplicatedFrom   FormConfig?  @relation("FormDuplication", fields: [duplicatedFromId], references: [id], onDelete: SetNull)
  duplicates       FormConfig[] @relation("FormDuplication")

  @@map("form_configs")
}

// ─────────────────────────────────────────────
// 3. SUBMISSION
// ─────────────────────────────────────────────

model Submission {
  id            String    @id @default(uuid())
  applicationId String    @unique @map("application_id")  // ETH-{YEAR}-{SEQ}
  title         String
  track         Track     @default(FULL)
  status        String    @default("DRAFT") @db.VarChar(40)
  formConfigId  String    @map("form_config_id")
  authorId      String    @map("author_id")
  reviewerId    String?   @map("reviewer_id")
  parentId      String?   @map("parent_id")               // For continuation submissions
  isActive      Boolean   @default(true) @map("is_active")
  submittedAt   DateTime? @map("submitted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  formConfig   FormConfig         @relation(fields: [formConfigId], references: [id])
  author       User               @relation("SubmissionAuthor", fields: [authorId], references: [id])
  reviewer     User?              @relation("SubmissionReviewer", fields: [reviewerId], references: [id])
  parent       Submission?        @relation("SubmissionContinuation", fields: [parentId], references: [id])
  continuations Submission[]      @relation("SubmissionContinuation")
  versions     SubmissionVersion[]
  comments     Comment[]
  slaTracking  SLATracking?
  aiAnalyses   AIAnalysis[]
  agendaItems  MeetingAgendaItem[]
  documents    Document[]
  statusConfig SubmissionStatus @relation("SubmissionStatusRelation", fields: [status], references: [code])
  committeeVotes       SubmissionVote[]
  conflictDeclarations ConflictDeclaration[]     @relation("ConflictTargetSubmission")
  checklistReviews     ReviewerChecklistReview[]

  @@map("submissions")
}

// ─────────────────────────────────────────────
// 4. SUBMISSION VERSION
// ─────────────────────────────────────────────

model SubmissionVersion {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  versionNum   Int      @map("version_num")
  dataJson     Json     @map("data_json")    // Full form data snapshot
  changedBy    String   @map("changed_by")  // User ID
  changeNote   String?  @map("change_note")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])

  @@unique([submissionId, versionNum])
  @@map("submission_versions")
}

// ─────────────────────────────────────────────
// 5. COMMENT
// ─────────────────────────────────────────────

model Comment {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  authorId     String   @map("author_id")
  content      String
  fieldKey     String?  @map("field_key")   // Optional: comment on a specific field
  isInternal   Boolean  @default(false) @map("is_internal")  // Internal = reviewers only
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])
  author     User       @relation(fields: [authorId], references: [id])

  @@map("comments")
}

// ─────────────────────────────────────────────
// 6. SLA TRACKING
// ─────────────────────────────────────────────

model SLATracking {
  id              String    @id @default(uuid())
  submissionId    String    @unique @map("submission_id")
  triageDue       DateTime? @map("triage_due")
  reviewDue       DateTime? @map("review_due")
  revisionDue     DateTime? @map("revision_due")
  approvalDue     DateTime? @map("approval_due")
  triageCompleted DateTime? @map("triage_completed")
  reviewCompleted DateTime? @map("review_completed")
  isBreached      Boolean   @default(false) @map("is_breached")
  warningsSent    Int       @default(0) @map("warnings_sent")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("sla_tracking")
}

// ─────────────────────────────────────────────
// 7. AI ANALYSIS
// ─────────────────────────────────────────────

model AIAnalysis {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  requestedBy  String   @map("requested_by")  // User ID
  provider     String                          // "mock" | "gemini"
  prompt       String
  resultJson   Json     @map("result_json")   // Advisory only — never blocks
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  submission Submission @relation(fields: [submissionId], references: [id])
  requester  User       @relation(fields: [requestedBy], references: [id])

  @@map("ai_analyses")
}

// ─────────────────────────────────────────────
// 8. AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")     // Nullable for system actions
  action     String                        // e.g. "submission.approved"
  entityType String   @map("entity_type") // e.g. "Submission"
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metaJson   Json?    @map("meta_json")   // Extra context
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// 9. INSTITUTION SETTING
// ─────────────────────────────────────────────

model InstitutionSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  valueType String   @default("string") @map("value_type")  // "string"|"number"|"boolean"|"json"
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("institution_settings")
}

model SubmissionStatus {
  id               String           @id @default(uuid())
  code             String           @unique @db.VarChar(40)
  labelHe          String           @map("label_he")
  labelEn          String           @map("label_en")
  descriptionHe    String?          @map("description_he")
  descriptionEn    String?          @map("description_en")
  color            String           @default("#64748b")
  orderIndex       Int              @default(0) @map("order_index")
  isInitial        Boolean          @default(false) @map("is_initial")
  isTerminal       Boolean          @default(false) @map("is_terminal")
  slaPhase         SlaPhase?        @map("sla_phase")
  notificationType NotificationType? @map("notification_type")
  isSystem         Boolean          @default(false) @map("is_system")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  submissions      Submission[]     @relation("SubmissionStatusRelation")
  transitionsFrom  StatusTransition[] @relation("StatusTransitionFrom")
  transitionsTo    StatusTransition[] @relation("StatusTransitionTo")
  permissions      StatusPermission[]

  @@index([isActive, orderIndex])
  @@map("submission_statuses")
}

model StatusTransition {
  id                 String           @id @default(uuid())
  fromStatusId       String           @map("from_status_id")
  toStatusId         String           @map("to_status_id")
  allowedRoles       Role[]           @default([])
  requireReviewerAssigned Boolean     @default(false) @map("require_reviewer_assigned")
  isActive           Boolean          @default(true) @map("is_active")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  fromStatus         SubmissionStatus @relation("StatusTransitionFrom", fields: [fromStatusId], references: [id])
  toStatus           SubmissionStatus @relation("StatusTransitionTo", fields: [toStatusId], references: [id])

  @@unique([fromStatusId, toStatusId])
  @@index([fromStatusId, isActive])
  @@index([toStatusId, isActive])
  @@map("status_transitions")
}

model StatusPermission {
  id           String           @id @default(uuid())
  statusId     String           @map("status_id")
  role         Role
  action       StatusAction
  allowed      Boolean          @default(false)
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  status       SubmissionStatus @relation(fields: [statusId], references: [id])

  @@unique([statusId, role, action])
  @@index([statusId, role, isActive])
  @@map("status_permissions")
}

// ─────────────────────────────────────────────
// 10. MEETING
// ─────────────────────────────────────────────

model Meeting {
  id           String        @id @default(uuid())
  title        String
  scheduledAt  DateTime      @map("scheduled_at")
  location     String?
  meetingLink  String?       @map("meeting_link")
  status       MeetingStatus @default(SCHEDULED)
  agendaNote   String?       @map("agenda_note")
  minutesNote  String?       @map("minutes_note")
  isActive           Boolean       @default(true) @map("is_active")
  externalCalendarId String?       @map("external_calendar_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  // Relations
  agendaItems MeetingAgendaItem[]
  attendees   MeetingAttendee[]
  calendarSyncs MeetingCalendarSync[]
  protocols   Protocol[]

  @@map("meetings")
}

// ─────────────────────────────────────────────
// 10.1 MEETING CALENDAR SYNC (per user)
// ─────────────────────────────────────────────

model MeetingCalendarSync {
  id              String             @id @default(uuid())
  meetingId       String             @map("meeting_id")
  userId          String             @map("user_id")
  provider        CalendarProvider
  externalEventId String?            @map("external_event_id")
  status          CalendarSyncStatus @default(PENDING)
  retryCount      Int                @default(0) @map("retry_count")
  lastError       String?            @map("last_error")
  lastAttemptAt   DateTime?          @map("last_attempt_at")
  nextRetryAt     DateTime?          @map("next_retry_at")
  lastSyncAt      DateTime?          @map("last_sync_at")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([status, nextRetryAt])
  @@index([userId, status])
  @@map("meeting_calendar_syncs")
}

// ─────────────────────────────────────────────
// 11. MEETING AGENDA ITEM
// ─────────────────────────────────────────────

model MeetingAgendaItem {
  id           String    @id @default(uuid())
  meetingId    String    @map("meeting_id")
  submissionId String    @map("submission_id")
  orderIndex   Int       @map("order_index")
  decision     Decision  @default(PENDING)
  decisionNote String?   @map("decision_note")
  duration     Int?                            // Minutes allocated
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  meeting    Meeting    @relation(fields: [meetingId], references: [id])
  submission Submission @relation(fields: [submissionId], references: [id])

  @@unique([meetingId, submissionId])
  @@map("meeting_agenda_items")
}

// ─────────────────────────────────────────────
// 12. MEETING ATTENDEE
// ─────────────────────────────────────────────

model MeetingAttendee {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  attended  Boolean  @default(false)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  meeting Meeting @relation(fields: [meetingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("meeting_attendees")
}

// ─────────────────────────────────────────────
// 13. PROTOCOL
// ─────────────────────────────────────────────

model Protocol {
  id          String         @id @default(uuid())
  meetingId   String         @map("meeting_id")
  title       String
  contentJson Json           @map("content_json")  // Rich text as JSON
  status      ProtocolStatus @default(DRAFT)
  isActive    Boolean        @default(true) @map("is_active")
  finalizedAt DateTime?      @map("finalized_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  // Relations
  meeting    Meeting             @relation(fields: [meetingId], references: [id])
  signatures ProtocolSignature[]
  documents  Document[]

  @@map("protocols")
}

// ─────────────────────────────────────────────
// 14. PROTOCOL SIGNATURE
// ─────────────────────────────────────────────

model ProtocolSignature {
  id          String          @id @default(uuid())
  protocolId  String          @map("protocol_id")
  userId      String          @map("user_id")
  status      SignatureStatus @default(PENDING)
  token       String?         @unique   // Email link token
  tokenExpiry DateTime?       @map("token_expiry")
  signedAt    DateTime?       @map("signed_at")
  ipAddress   String?         @map("ip_address")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // Relations
  protocol Protocol @relation(fields: [protocolId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([protocolId, userId])
  @@map("protocol_signatures")
}

// ─────────────────────────────────────────────
// 15. NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  type       NotificationType
  titleKey   String           @map("title_key")   // i18n key
  bodyKey    String           @map("body_key")    // i18n key
  metaJson   Json?            @map("meta_json")   // Dynamic values for i18n interpolation
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at")
  isActive   Boolean          @default(true) @map("is_active")
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// 16. DOCUMENT
// ─────────────────────────────────────────────

model Document {
  id           String         @id @default(uuid())
  filename     String
  originalName String         @map("original_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  storagePath  String         @map("storage_path")   // Relative path in STORAGE_PROVIDER
  source       DocumentSource @default(UPLOADED)
  submissionId String?        @map("submission_id")
  protocolId   String?        @map("protocol_id")
  uploadedById String?        @map("uploaded_by_id") // NULL for system-generated
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")

  // Relations
  submission Submission? @relation(fields: [submissionId], references: [id])
  protocol   Protocol?   @relation(fields: [protocolId], references: [id])
  uploadedBy User?       @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@map("documents")
}

model PrivacyConsent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  consentType String   @map("consent_type")
  policyVersion String @map("policy_version")
  accepted    Boolean
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("privacy_consents")
}

model DataSubjectRequest {
  id          String                  @id @default(uuid())
  userId      String                  @map("user_id")
  type        DataSubjectRequestType
  status      DataSubjectRequestStatus @default(OPEN)
  details     String?
  requestedAt DateTime                @default(now()) @map("requested_at")
  resolvedAt  DateTime?               @map("resolved_at")
  resolutionNote String?              @map("resolution_note")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, requestedAt])
  @@map("data_subject_requests")
}

model SubmissionVote {
  id           String                @id @default(uuid())
  submissionId String                @map("submission_id")
  voterId      String                @map("voter_id")
  decision     CommitteeVoteDecision
  note         String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submissionId], references: [id])
  voter      User       @relation(fields: [voterId], references: [id])

  @@unique([submissionId, voterId])
  @@index([submissionId, createdAt])
  @@map("submission_votes")
}

model ConflictDeclaration {
  id                 String        @id @default(uuid())
  declarerId         String        @map("declarer_id")
  scope              ConflictScope
  targetSubmissionId String?       @map("target_submission_id")
  targetUserId       String?       @map("target_user_id")
  targetDepartment   String?       @map("target_department")
  reason             String
  isActive           Boolean       @default(true) @map("is_active")
  declaredAt         DateTime      @default(now()) @map("declared_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  declarer           User          @relation("ConflictDeclarer", fields: [declarerId], references: [id])
  targetSubmission   Submission?   @relation("ConflictTargetSubmission", fields: [targetSubmissionId], references: [id])
  targetUser         User?         @relation("ConflictTargetUser", fields: [targetUserId], references: [id])

  @@index([declarerId, isActive])
  @@index([targetSubmissionId, isActive])
  @@index([targetUserId, isActive])
  @@index([scope, isActive])
  @@map("conflict_declarations")
}

// ─────────────────────────────────────────────
// SYSTEM TEMPLATES
// ─────────────────────────────────────────────

model SystemTemplate {
  id          String   @id @default(uuid())
  key         String                         // "questionnaire_preface", extensible for future templates
  lang        String                         // "he" or "en"
  version     Int                            // 1, 2, 3... incrementing per key+lang combination
  filename    String                         // original upload filename for display
  storagePath String   @map("storage_path")  // STORAGE_PROVIDER path: templates/{key}/v{version}/{lang}.{ext}
  mimeType    String   @map("mime_type")     // application/pdf or application/vnd.openxmlformats-officedocument.wordprocessingml.document
  size        Int                            // bytes
  isActive    Boolean  @default(true) @map("is_active") // false = archived version, true = current version per key+lang
  uploadedBy  String                         @map("uploaded_by")
  createdAt   DateTime @default(now())       @map("created_at")
  updatedAt   DateTime @updatedAt            @map("updated_at")

  uploader    User     @relation(fields: [uploadedBy], references: [id])

  @@unique([key, lang, version])
  @@index([key, lang, isActive])
  @@index([key, isActive])
  @@map("system_templates")
}

// ─────────────────────────────────────────────
// REVIEWER CHECKLIST
// ─────────────────────────────────────────────

// Master checklist template managed by Admin.
// track: null = applies to all tracks, otherwise "FULL" | "EXPEDITED" | "EXEMPT".
// Only one active template per track (null counts as its own track).
// Publishing a template deactivates the previous active one for the same track.
model ReviewerChecklistTemplate {
  id          String    @id @default(uuid())
  name        String
  nameEn      String    @map("name_en")
  version     Int       @default(1)
  track       String?                          // null = all tracks
  isActive    Boolean   @default(false) @map("is_active")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sections ReviewerChecklistSection[]
  reviews  ReviewerChecklistReview[]

  @@index([isActive, track])
  @@map("reviewer_checklist_templates")
}

// A section within a template (e.g. "Document Approval", "Ethical Issues").
// answerType controls what radio options appear for all items in this section.
// yesIsProblem: when true, a YES answer is highlighted as a problem (amber/red).
model ReviewerChecklistSection {
  id           String              @id @default(uuid())
  templateId   String              @map("template_id")
  code         String                               // "DOCS" | "ETHICS" | "SUMMARY"
  title        String
  titleEn      String              @map("title_en")
  description  String?
  answerType   ChecklistAnswerType @map("answer_type")
  yesIsProblem Boolean             @default(false) @map("yes_is_problem")
  orderIndex   Int                 @map("order_index")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  template ReviewerChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    ReviewerChecklistItem[]

  @@unique([templateId, code])
  @@index([templateId, orderIndex])
  @@map("reviewer_checklist_sections")
}

// A single checklist item within a section.
// requiresDetails: when true, reviewer must fill a text field if answer is negative.
// conditional: JSON { dependsOn: "<itemCode>", showWhen: "YES" | "NO" | "ADEQUATE" | "INADEQUATE" }.
// isActive: soft-delete only; items with existing responses must never be hard-deleted.
model ReviewerChecklistItem {
  id              String   @id @default(uuid())
  sectionId       String   @map("section_id")
  code            String
  label           String
  labelEn         String   @map("label_en")
  helpText        String?  @map("help_text")
  helpTextEn      String?  @map("help_text_en")
  orderIndex      Int      @map("order_index")
  isRequired      Boolean  @default(true) @map("is_required")
  requiresDetails Boolean  @default(false) @map("requires_details")
  conditional     Json?                             // { dependsOn, showWhen }
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  section   ReviewerChecklistSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  responses ReviewerChecklistResponse[]

  @@unique([sectionId, code])
  @@index([sectionId, orderIndex, isActive])
  @@map("reviewer_checklist_items")
}

// One review per reviewer per submission.
// templateId is snapshotted at creation time so future template edits don't alter existing reviews.
// Summary fields (exemptConsent*, minors*) represent Section C conditional questions.
model ReviewerChecklistReview {
  id                        String                  @id @default(uuid())
  submissionId              String                  @map("submission_id")
  reviewerId                String                  @map("reviewer_id")
  templateId                String                  @map("template_id")
  status                    ChecklistReviewStatus   @default(DRAFT)
  recommendation            ChecklistRecommendation?
  generalNote               String?                 @map("general_note") @db.Text
  exemptConsentRequested    Boolean?                @map("exempt_consent_requested")
  exemptConsentReviewerView String?                 @map("exempt_consent_reviewer_view")  // "APPROVE" | "REJECT"
  minorsBothParentsExempt   Boolean?                @map("minors_both_parents_exempt")
  minorsExemptReviewerView  String?                 @map("minors_exempt_reviewer_view")   // "APPROVE" | "REJECT"
  submittedAt               DateTime?               @map("submitted_at")
  createdAt                 DateTime                @default(now()) @map("created_at")
  updatedAt                 DateTime                @updatedAt @map("updated_at")

  submission Submission                  @relation(fields: [submissionId], references: [id])
  reviewer   User                        @relation("ReviewerChecklistReviews", fields: [reviewerId], references: [id])
  template   ReviewerChecklistTemplate   @relation(fields: [templateId], references: [id])
  responses  ReviewerChecklistResponse[]

  @@unique([submissionId, reviewerId])
  @@index([submissionId, status])
  @@index([reviewerId, status])
  @@map("reviewer_checklist_reviews")
}

// One response per item per review.
// itemCode is snapshotted at save time for audit trail stability.
// answer values: "ADEQUATE" | "INADEQUATE" | "YES" | "NO" | "NA".
model ReviewerChecklistResponse {
  id       String   @id @default(uuid())
  reviewId String   @map("review_id")
  itemId   String   @map("item_id")
  itemCode String   @map("item_code")              // snapshot of item.code
  answer   String                                  // ADEQUATE | INADEQUATE | YES | NO | NA
  details  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review ReviewerChecklistReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  item   ReviewerChecklistItem   @relation(fields: [itemId], references: [id])

  @@unique([reviewId, itemId])
  @@index([reviewId])
  @@map("reviewer_checklist_responses")
}
