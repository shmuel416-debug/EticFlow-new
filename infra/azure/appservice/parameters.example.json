{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "westeurope"
    },
    "environmentName": {
      "value": "prod"
    },
    "appServicePlanName": {
      "value": "asp-ethicflow-prod"
    },
    "apiAppName": {
      "value": "app-ethicflow-api-prod"
    },
    "webAppName": {
      "value": "app-ethicflow-web-prod"
    },
    "acrName": {
      "value": "acrethicflowprod"
