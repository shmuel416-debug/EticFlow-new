# ═══════════════════════════════════════════════════
# Ethic-Net — .gitignore
# ═══════════════════════════════════════════════════

# Dependencies
node_modules/

# Environment (secrets!)
.env
.env.local
.env.*.local
!.env.example

# Build outputs
dist/
build/

# Uploaded & generated files
uploads/
generated/

# Database
pgdata/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Testing
coverage/
.nyc_output/
tmp_*.txt
tmp_*.mjs
tmp_*.json
tmp_*.pdf
tmp_*.exe
frontend/playwright-report/
frontend/test-results/

# Prisma
backend/prisma/migrations/**/migration_lock.toml

# Azure infra parameter files (contain secrets!)
# Keep only .example variants committed to git.
infra/azure/appservice/parameters.prod.json
infra/azure/appservice/parameters.dev.json
infra/azure/appservice/parameters.staging.json
infra/azure/appservice/parameters.local.json
infra/azure/terraform/terraform.tfvars
infra/azure/terraform/*.auto.tfvars
infra/azure/terraform/*.tfstate
infra/azure/terraform/*.tfstate.*
infra/azure/terraform/.terraform/
ops/secrets/
*.secrets.json
